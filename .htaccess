# Activar motor de reescritura
RewriteEngine On

# Redirigir HTTP a HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirigir non-www a www (ya en HTTPS)
RewriteCond %{HTTP_HOST} ^laserinova\.com$ [NC]
RewriteRule ^(.*)$ https://www.laserinova.com/$1 [L,R=301]

# --- REDIRECCIONES 301 (MIGRACIÓN SEO) ---
# Evita la pérdida de autoridad redirigiendo URLs antiguas a su nueva ubicación B2B
Redirect 301 /grabado_metal.html /subpages/grabado_metal.html
Redirect 301 /corte_laser.html /subpages/maquila_volumen.html
Redirect 301 /grabado_madera.html /subpages/grabado_madera.html
Redirect 301 /grabado_corte_acrilico.html /subpages/displays_materiales_visuales.html
Redirect 301 /impresion_dft_uv.html /subpages/impresion_cama_plana_uv.html
Redirect 301 /grabado_corporativo.html /subpages/promocionales_premium.html
Redirect 301 /blog/grabado_metal.html /blog/grabado-metal-volumen.html

# Establecer index.html como archivo por defecto
DirectoryIndex index.html

# Forzar que los archivos .xml se sirvan con el tipo MIME correcto
AddType application/xml .xml

# --- CONFIGURACIÓN DE CACHÉ DE NAVEGADOR (Lighthouse Optimization) ---
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType application/x-javascript "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/icon "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  # Forzar Cache-Control a 1 año (31536000 segundos) para asegurar que se aplique
  <FilesMatch "\.(ico|pdf|flv|jpg|jpeg|png|gif|webp|svg|js|css|woff2?)$">
    Header set Cache-Control "max-age=31536000, public"
  </FilesMatch>
</IfModule>
